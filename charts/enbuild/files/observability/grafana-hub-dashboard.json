  },
  "description": "BE 032 — ENBUILD hub gRPC observability. Eight metrics scraped from /api/metrics on the bk Pod via the chart-side ServiceMonitor. Joinable with BE 031 SIEM logs by correlationId.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Agents connected",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(enbuild_agent_connections_active)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "type": "stat",
      "title": "RPC throughput (5m rate)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(enbuild_rpc_dispatch_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "reqps",
          "decimals": 2
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "type": "stat",
      "title": "Error rate (5m)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(enbuild_rpc_dispatch_total{decision!=\"allow\"}[5m])) / clamp_min(sum(rate(enbuild_rpc_dispatch_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          },
          "unit": "percentunit",
          "decimals": 2
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "type": "stat",
      "title": "Audit emit rate (5m)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(rate(enbuild_audit_events_emitted_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "reqps",
          "decimals": 2
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "type": "timeseries",
      "title": "RPC throughput by action (5m rate, stacked)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 5,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (action) (rate(enbuild_rpc_dispatch_total[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" }
      }
    },
    {
      "type": "timeseries",
      "title": "RPC latency p50/p95/p99 by action",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 6,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, action) (rate(enbuild_rpc_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{action}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, action) (rate(enbuild_rpc_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{action}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, action) (rate(enbuild_rpc_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{action}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0 },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" }
      }
    },
    {
      "type": "piechart",
      "title": "Tenancy decisions (5m)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(enbuild_tenancy_decisions_total[5m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      }
    },
    {
      "type": "piechart",
      "title": "mTLS handshakes (5m)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum by (result) (rate(enbuild_mtls_handshakes_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      }
    },
    {
      "type": "timeseries",
      "title": "Audit events emitted by event_type",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 9,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(enbuild_audit_events_emitted_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "sum"], "displayMode": "table", "placement": "right" }
      }
    },
    {
      "type": "timeseries",
      "title": "Per-cluster heartbeat rate (small multiples)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 10,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum by (cluster_id) (rate(enbuild_agent_heartbeats_total[5m]))",
          "legendFormat": "{{cluster_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0 },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right" }
      }
    },
    {
      "type": "stat",
      "title": "Proto translation errors (canary — should be 0)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "id": 11,
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 44 },
      "targets": [
        { "expr": "sum(rate(enbuild_proto_translation_errors_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          },
          "unit": "reqps",
          "decimals": 4
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    }
